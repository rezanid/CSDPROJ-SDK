{
  "$schema": "https://raw.githubusercontent.com/dotnet/Nerdbank.GitVersioning/main/src/NerdBank.GitVersioning/version.schema.json",
  "version": "1.0.0-alpha",
  "pathFilters": ["."],
  "nugetPackageVersion": {
     "semVer": 1 ,
     "precision": "build"
  },
  "publicReleaseRefSpec": [
    "^refs/heads/main",
    "^refs/heads/v\\d+(?:\\.\\d+)?$"
  ],
  "release" : {
    "tagName" : "webproj-v-{version}",
    "branchName" : "webproj-v-{version}",
    "versionIncrement" : "build",
    "firstUnstableTag" : "alpha"
  },
  "cloudBuild": {
    "buildNumber": {
      "enabled": true
    }
  }
}